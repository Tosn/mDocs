{
  "name": "mdocs",
  "version": "0.1.0",
  "description": "桌面端文档查看 / 搜索 / AI 问答工具",
  "main": "out/main/index.js",
  "author": "Tosn <taoserking1@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "electron-builder install-app-deps && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-builder install-app-deps && electron-vite preview",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/ensure-sqlite-electron.mjs",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:sqlite": "node scripts/ensure-sqlite-electron.mjs",
    "rebuild:node": "npm rebuild better-sqlite3",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@tanstack/react-query": "^5.59.0",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.5.0",
    "codemirror": "^6.0.1",
    "jsdom": "^25.0.1",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "sqlite-vec": "^0.1.6",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "sqlite-vec"
    ]
  }
}
